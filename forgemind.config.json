{
  "outputPath": "docs",
  "intermediatePath": "ai",
  "ignoreDirs": [
    ".git",
    "node_modules",
    "dist",
    "coverage",
    ".next",
    "__pycache__",
    "venv",
    ".venv",
    "vendor",
    "target"
  ],
  "ignoreFilePatterns": [
    ".*",
    "*.tmp",
    "*.temp",
    "*.swp",
    "*.swo",
    "*.bak",
    "*~"
  ],
  "llm": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "temperature": 0.3,
    "maxTokensBudget": 300000,
    "apiKey": "REMOVED_GOOGLE_API_KEY"
  },
  "qualityGate": {
    "minConfidence": 0.65,
    "maxPendingRatio": 0.45
  },
  "interview": {
    "maxQuestions": 8,
    "adaptiveFollowUp": true,
    "language": "en"
  }
}