{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgemind.dev/schemas/llmResponse.schema.json",
  "title": "ForgeMind LLM Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["enrichedContent", "metadata"],
  "properties": {
    "enrichedContent": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["openai", "openai-compatible", "anthropic", "azure", "local"]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1
        },
        "tokensUsed": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
